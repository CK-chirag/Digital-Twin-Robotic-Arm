          filename="package://mycobot_description/meshes/arm/accessory_02.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="accessory02"
    type="revolute">
    <origin
      xyz="0.053859 0.027025 -0.0083546"
      rpy="-1.5732 0 0" />
    <parent
      link="link_05" />
    <child
      link="accessory_02" />
    <axis
      xyz="-0.19539 0 0.98073" />
    <limit
      lower="-0.1483"
      upper="0.253"
      effort="0"
      velocity="0" />
    <mimic
      joint="gear01"
      multiplier="1"
      offset="0" />
  </joint>

  <!-- Mimic behavior is defined by URDF mimic tags on joints.
       Do not load extra mimic plugins here for Gazebo Sim. -->

  <!-- Transmissions -->
  <xacro:default_transmission number="link01"/>
  <xacro:default_transmission number="link02"/>
  <xacro:default_transmission number="link03"/>
  <xacro:default_transmission number="link04"/>
  <xacro:default_transmission number="link05"/>
  <xacro:default_transmission number="gear01"/>
  <!-- FIX 5: Removed gripper01 and gripper02 transmissions (fixed joints) -->
  <xacro:default_transmission number="gear02"/>
  <xacro:default_transmission number="accessory01"/>
  <xacro:default_transmission number="accessory02"/>

  <xacro:mycobot_ros2_control
    prefix="$(arg prefix)"
    flange_link="$(arg flange_link)"
    use_gazebo="$(arg use_gazebo)" />

  <xacro:load_gazebo_sim_ros2_control_plugin
    robot_name="$(arg robot_name)"
    use_gazebo="$(arg use_gazebo)" />
</robot>