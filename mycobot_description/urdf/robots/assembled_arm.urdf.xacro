      rpy="-1.5732 0 0" />
    <parent
      link="link_05" />
    <child
      link="gear_02" />
    <axis
      xyz="-0.19539 0 0.98073" />
    <limit
      lower="-0.1483"
      upper="0.253"
      effort="0"
      velocity="0" />
    <mimic
      joint="gear01"
      multiplier="-1"
      offset="0" />
  </joint>
  <link
    name="gripper_02">
    <inertial>
      <origin
        xyz="0.0278050946308295 0.00549352470343977 -0.00287248750004027"
        rpy="0 0 0" />
      <mass
        value="0.00539747216743088" />
      <inertia
