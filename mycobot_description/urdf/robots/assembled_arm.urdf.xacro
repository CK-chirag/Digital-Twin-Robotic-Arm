      </geometry>
    </collision>
  </link>
  <!-- FIX 2: accessory01 now mimics gear01 directly (not gear02 chain) -->
  <!-- multiplier=-1 because: gear02=-1*gear01, accessory01=1*gear02 => net -1*gear01 -->
  <joint
    name="accessory01"
    type="revolute">
    <origin
      xyz="0.05374 0.027025 0.0016447"
      rpy="-1.5732 0 0" />
    <parent
      link="link_05" />
    <child
      link="accessory_01" />
    <axis
      xyz="-0.19539 0 0.98073" />
    <limit
      lower="-0.1483"
      upper="0.253"
      effort="${effort}"
      velocity="${velocity}" />
    <mimic
      joint="gear01"
      multiplier="-1"
      offset="0" />
  </joint>
  <link
    name="accessory_02">
    <inertial>
      <origin
        xyz="0.0123033749142943 0.00910321001325608 0.00245123094881883"
        rpy="0 0 0" />
      <mass
        value="0.000798762413184687" />
      <inertia
        ixx="4.0420468446262E-08"
        ixy="-4.62868531159467E-08"
        ixz="-1.27516223525543E-08"
        iyy="6.86743266789957E-08"
        iyz="-9.22184097498933E-09"
