    <origin
      xyz="0.024027 0.018046 0.0068263"
      rpy="0 0 0" />
    <parent
      link="gear_01" />
    <child
      link="gripper_01" />
    <axis
      xyz="0 0 0" />
  </joint>
  <link
    name="gear_02">
    <inertial>
      <origin
        xyz="0.00526569330330506 -0.00260322663434469 -0.00099021055503537"
        rpy="0 0 0" />
      <mass
        value="0.00644553641449659" />
      <inertia
