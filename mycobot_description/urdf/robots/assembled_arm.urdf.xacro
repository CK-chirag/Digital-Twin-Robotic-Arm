<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mycobot_description">

  <xacro:arg name="robot_name" default="mycobot_280" />
  <xacro:arg name="prefix" default="" />
  <xacro:arg name="flange_link" default="link_5" />
  <xacro:arg name="use_gazebo" default="false" />

  <!-- Include Gazebo Parameters -->
  <xacro:include filename="$(find mycobot_description)/urdf/control/gazebo_sim_ros2_control.urdf.xacro" />

  <!-- Include ros2_control Plugins -->
  <xacro:include filename="$(find mycobot_description)/urdf/control/mycobot_280_ros2_control.urdf.xacro" />

  <!-- Useful XACRO Variables (Properties) -->
  <xacro:property name="PI" value="3.14159265359" />
  <xacro:property name="effort" value="30.0" />
  <xacro:property name="velocity" value="2.0" />

  <xacro:macro name="default_transmission" params="number">
      <transmission name="{number}">
          <plugin>transmission_interface/SimpleTransmission</plugin>
          <actuator name="${number}" role="actuator1"/>
          <joint name="${number}"    role="joint1">
              <mechanical_reduction>1.0</mechanical_reduction>
          </joint>
      </transmission>
  </xacro:macro>

  <link name="world"/>
  <link
    name="base_link">
    <inertial>
      <origin
        xyz="7.9356E-05 8.6233E-05 0.022304"
        rpy="0 0 0" />
      <mass
        value="0.23433" />
      <inertia
        ixx="0.00032508"
        ixy="-1.1755E-05"
        ixz="6.4669E-06"
        iyy="0.00032312"
        iyz="7.0274E-06"
        izz="0.00050748" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycobot_description/meshes/arm/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.84706 0.84706 0.84706 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycobot_description/meshes/arm/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="virtual_joint" type="fixed">
      <parent link="world"/>
      <child link="base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint> 
  
  <link
    name="link_01">
    <inertial>
      <origin
        xyz="0.0013721 0.0064346 0.013289"
        rpy="0 0 0" />
      <mass
        value="0.16601" />
      <inertia
        ixx="0.00010985"
        ixy="-1.566E-06"
        ixz="-1.5234E-05"
        iyy="0.00014185"
        iyz="-1.2633E-05"
        izz="0.00013341" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycobot_description/meshes/arm/link_01.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.84706 0.84706 0.84706 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mycobot_description/meshes/arm/link_01.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="link01"
    type="revolute">
    <origin
      xyz="0 0 0.06"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="link_01" />
    <axis
      xyz="0 0 -1" />
    <limit
      lower="-${PI / 2}"
      upper="${PI / 2}"
      effort="${effort}"
      velocity="${velocity}" />
  </joint>
  <link
    name="link_02">
    <inertial>
      <origin
        xyz="0.057471 0.010862 0.0081673"
        rpy="0 0 0" />
