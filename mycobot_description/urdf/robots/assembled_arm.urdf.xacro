      rpy="0 0 0" />
    <parent
      link="gear_02" />
    <child
      link="gripper_02" />
    <axis
      xyz="0 0 0" />
  </joint>
  <link
    name="accessory_01">
    <inertial>
      <origin
        xyz="0.0127366608297049 -0.0084609859228708 0.00253755554283913"
        rpy="0 0 0" />
      <mass
        value="0.000798762413184688" />
      <inertia
        ixx="3.5936646569313E-08"
